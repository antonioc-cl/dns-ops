# DNS Ops Workbench Environment Configuration
# See docs/architecture/runtime-topology.md for full topology documentation

# =============================================================================
# LOCAL DEVELOPMENT (Required for local dev)
# =============================================================================

# PostgreSQL connection string (authoritative data store)
# Both web and collector connect to the same database
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/dns_ops

# Collector service URL (web app calls this to trigger collection)
COLLECTOR_URL=http://localhost:3001

# =============================================================================
# STAGING / PRODUCTION (Set via platform secrets)
# =============================================================================

# For Cloudflare Workers (web app):
# - HYPERDRIVE binding configured in wrangler.jsonc
# - COLLECTOR_URL set in wrangler.jsonc vars

# For collector (Node.js container):
# - DATABASE_URL: production PostgreSQL connection string
# - NODE_ENV: 'production' or 'staging'

# =============================================================================
# OPTIONAL
# =============================================================================

# Log level (debug, info, warn, error)
LOG_LEVEL=info

# Enable tracing
# ENABLE_TRACING=true

# Rate limiting (requests per minute per IP)
# RATE_LIMIT_RPM=60
