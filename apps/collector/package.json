{
  "name": "@dns-ops/collector",
  "version": "0.1.0",
  "description": "DNS Ops Collector Worker - Node.js service for DNS/mail collection and probes",
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "biome check src",
    "test": "vitest run src",
    "docker:build": "docker build -t dns-ops-collector .",
    "docker:run": "docker run -p 3001:3001 --env-file .env dns-ops-collector"
  },
  "dependencies": {
    "@dns-ops/contracts": "workspace:*",
    "@dns-ops/db": "workspace:*",
    "@dns-ops/parsing": "workspace:*",
    "@hono/node-server": "^1.8.0",
    "bullmq": "^5.1.0",
    "hono": "^3.12.0",
    "ioredis": "^5.3.0",
    "node-dns": "^0.1.0"
  },
  "devDependencies": {
    "@types/node": "^20.10.0",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^4.1.0"
  }
}
